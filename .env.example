# =============================================================================
# Chelsea Bot (BlueBanter TS) — environment template
#
# HOW TO USE
#   1. Copy this file: `cp .env.example .env`
#   2. Fill in the values you have. Leave the rest blank.
#   3. NEVER commit .env — it's gitignored.
#
# Minimum needed per workflow:
#   - Generate tweets only  : OPENROUTER_API_KEY
#   - Run the cron jobs      : + API_FOOTBALL_KEY, NEON_DATABASE_URL
#   - Actually post to X     : + X_CLIENT_ID, X_CLIENT_SECRET, X_REDIRECT_URI
#   - Production observability: + SENTRY_DSN, OTLP_ENDPOINT
# =============================================================================

# ---- LLM -----------------------------------------------------------------
# Required. OpenRouter routes to x-ai/grok-4.1-fast by default.
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Alternate image/text model via Google. Not required for MVP.
GEMINI_API_KEY=

# ---- Football data --------------------------------------------------------
# Free tier: 100 requests/day. https://www.api-football.com/
API_FOOTBALL_KEY=

# ---- Storage --------------------------------------------------------------
# Required for crons/persistence. Any Postgres URL — the code currently uses
# the Neon serverless driver; for vanilla Postgres swap `drizzle-orm/neon-serverless`
# to `drizzle-orm/node-postgres` in packages/db/client.ts.
NEON_DATABASE_URL=

# Optional. If absent, caches fall back to in-memory (fine for local).
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ---- X / Twitter ----------------------------------------------------------
# Optional for local dev. Required to actually publish tweets.
# Create an X OAuth 2.0 app: https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/x/callback

# ---- Research / news (optional) -------------------------------------------
TAVILY_API_KEY=
NANO_BANANA_API_KEY=

# ---- Observability --------------------------------------------------------
SENTRY_DSN=
OTLP_ENDPOINT=
